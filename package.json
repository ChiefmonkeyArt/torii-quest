{
  "name": "torii-quest",
  "version": "0.2.196-alpha",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:continuum": "node tools/build-continuum.mjs",
    "build": "node tools/build-continuum.mjs && vite build",
    "preview": "vite preview",
    "check": "node tools/regression-check.mjs",
    "bundle:report": "node tools/bundle-report.mjs",
    "handoff:status": "node tools/handoff-status.mjs",
    "handoff:summary": "node tools/handoff-summary.mjs",
    "zones:check": "node tools/zone-fallback-check.mjs",
    "vps:dry-run": "node tools/vps-dry-run.mjs",
    "docs:stale": "node tools/stale-docs.mjs",
    "release:meta": "node tools/release-meta.mjs",
    "release:status": "node tools/release-readiness.mjs",
    "release:status:json": "node tools/release-readiness.mjs --json",
    "test": "vitest run",
    "test:fast": "node tools/test-profile.mjs fast",
    "test:foundation": "node tools/test-profile.mjs foundation",
    "test:release": "npm run build && vitest run && npm run check && npm run bundle:report && npm run handoff:status"
  },
  "devDependencies": {
    "vite": "^8.0.16",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "three": "^0.184.0"
  }
}
